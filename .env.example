# ============================================
# Datagami Website — Environment Variables
# Copy this file to .env and fill in values
# For Vercel: add these in Project Settings > Environment Variables
# ============================================

# --- Database (PostgreSQL) ---
# Local: postgresql://username@localhost:5432/datagami-website
# Vercel: Use Vercel Postgres or external DB (e.g., Supabase, Neon, Railway)
DATABASE_URL="postgresql://localhost:5432/datagami-website"

# --- NextAuth.js ---
# Generate secret: openssl rand -base64 32
# Vercel: Set NEXTAUTH_URL to your production domain (https://datagami.in)
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# --- Azure Blob Storage ---
# From: az storage account show-connection-string --name datagamistorage
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=datagamistorage;AccountKey=...;EndpointSuffix=core.windows.net"
AZURE_STORAGE_ACCOUNT_NAME="datagamistorage"
